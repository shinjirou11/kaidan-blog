---
import type { CollectionEntry } from 'astro:content';
import { url } from '../utils/url';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, category, tags } = entry.data;
const categoryLabel = category === 'kaidan' ? '怪談' : 'ホラー映画';
const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={url(`articles/${entry.id}`)} class="article-card">
  <div>
    <div class="article-card__meta">
      <span class="article-card__category">{categoryLabel}</span>
      <time class="article-card__date" datetime={pubDate.toISOString()}>{dateStr}</time>
    </div>
    <h2 class="article-card__title">{title}</h2>
    <p class="article-card__desc">{description}</p>
    {tags.length > 0 && (
      <div class="article-card__tags">
        {tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>
